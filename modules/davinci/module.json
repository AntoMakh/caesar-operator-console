{
    "name": "davinci",
    "description": "Da Vinci hashcat wrapper for hash cracking",
    "entry": "davinci.sh",
    "options": {
        "HASH": {
            "required": true,
            "description": "single hash or path to file containing hashes"
        },
        "WORDLIST": {
            "required": true,
            "type": "file",
            "must_exist": true
        },
        "HASH_TYPE": {
            "required": true,
            "default": "md5",
            "type": "choice",
            "choices": ["md5", "sha1", "sha256", "sha512"]
        }
    },
    "argument_order": [
        "HASH",
        "WORDLIST",
        "HASH_TYPE"
    ]
}
