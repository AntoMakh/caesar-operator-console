{
  "name": "suntzu",
  "description": "Directory enumeration tool",
  "entry": "suntzu.py",
  "options": {
    "TARGET": {
        "required": true
    },
    "PORT": {
        "required": true,
        "type": "integer",
        "min": 1,
        "max": 65535
    },
    "WORDLIST": {
        "required": true,
        "type": "file",
        "must_exist": true
    },
    "EXCLUDED_STATUS_CODES": {
        "required": false,
        "default": "404",
        "flag": "--exclude-codes"
    },
    "EXTENSIONS": {
        "required": false,
        "flag": "--extensions"
    }
  },
    "argument_order": [
    "TARGET",
    "PORT",
    "WORDLIST",
    "EXCLUDED_STATUS_CODES",
    "EXTENSIONS"
  ]
}
