{
    "name": "judas",
    "description": "Judas flag keyword Source Code grabber from directories",
    "entry": "judas_wrapper.sh",
    "options": {
        "HOST": {
            "required": true
        },
        "PORT": {
            "required": true,
            "type": "integer",
            "min": 1,
            "max": 65535
        },
        "FILE": {
            "required": true,
            "type": "file",
            "must_exist": true
        },
        "KEYWORD": {
            "required": true
        },
        "SCHEME": {
            "required": false,
            "default": "http",
            "type": "choice",
            "choices": ["http", "https"]
        }
    },
        "argument_order": [
        "HOST",
        "PORT",
        "FILE",
        "KEYWORD",
        "SCHEME"
    ]
}
